## c:/Users/Profe Hectaime/Documents/Otros/Socio/dlp-academy/web/dlp-academy/.env.example
# Copy this file to .env and set values locally.
# Never commit your .env file.

# Unique local identifier for your Copilot instance.
# Used for branch ownership, status claiming, and shared-session handoff tracking.
# Examples: you, fellow, pc1, pc2
COPILOT_PC_ID=you

# Optional local runtime mode.
NODE_ENV=development

# Set to 'true' to connect the app to Firebase local emulators instead of live Firebase.
# Requires: firebase emulators:start --only auth,firestore,storage,functions
VITE_USE_EMULATORS=false

# Admin SDK emulator hosts (used by test global-setup.ts when in emulator mode)
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099