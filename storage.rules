rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function authUid() {
      return !isSignedIn()
        ? null
        : (
          request.auth.uid != null
            ? request.auth.uid
            : (
              request.auth.token.uid != null
                ? request.auth.token.uid
                : request.auth.token.sub
            )
        );
    }

    function currentUserPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function currentUserLegacyPath() {
      return /databases/database/documents/users/$(request.auth.uid);
    }

    function hasCurrentUserDoc() {
      return isSignedIn() && (exists(currentUserPath()) || exists(currentUserLegacyPath()));
    }

    function currentUserData() {
      return exists(currentUserPath())
        ? get(currentUserPath()).data
        : (exists(currentUserLegacyPath()) ? get(currentUserLegacyPath()).data : null);
    }

    function currentUserRole() {
      return hasCurrentUserDoc()
        ? currentUserData().role
        : (isSignedIn() ? request.auth.token.role : null);
    }

    function currentUserInstitutionId() {
      return hasCurrentUserDoc()
        ? currentUserData().institutionId
        : (isSignedIn() ? request.auth.token.institutionId : null);
    }

    function isGlobalAdmin() {
      return currentUserRole() == 'admin';
    }

    function isInstitutionAdminOf(institutionId) {
      return currentUserRole() == 'institutionadmin'
        && currentUserInstitutionId() == institutionId;
    }

    function isOwnerUser(userId) {
      return isSignedIn() && authUid() == userId;
    }

    match /profile-pictures/{userId} {
      allow read: if isOwnerUser(userId) || isGlobalAdmin();
      allow write: if isOwnerUser(userId) || isGlobalAdmin();
    }

    match /institutions/{institutionId}/branding/{fileName} {
      allow read: if isSignedIn()
        && (isGlobalAdmin() || currentUserInstitutionId() == institutionId);
      allow write: if isSignedIn()
        && (isGlobalAdmin() || isInstitutionAdminOf(institutionId));
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
