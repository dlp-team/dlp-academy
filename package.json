{
  "name": "dlp-academy",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:rules": "firebase emulators:exec --only firestore,storage \"npm run test:rules:unit\"",
    "test:rules:unit": "vitest run --config vitest.rules.config.js",
    "test:e2e": "npx cross-env VITE_USE_EMULATORS=true FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 playwright test",
    "test:e2e:ui": "npx cross-env VITE_USE_EMULATORS=true FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 playwright test --ui",
    "test:e2e:emulator": "npx cross-env VITE_USE_EMULATORS=true FIRESTORE_EMULATOR_HOST=localhost:8080 FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 playwright test",
    "test:e2e:live": "playwright test",
    "security:scan:staged": "node scripts/security/high-confidence-diff-scan.cjs --staged",
    "security:scan:branch": "node scripts/security/high-confidence-diff-scan.cjs --range origin/main..HEAD"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "canvas-confetti": "^1.9.4",
    "dotenv": "^17.3.1",
    "firebase": "^12.8.0",
    "firebase-admin": "^13.6.1",
    "katex": "^0.16.28",
    "lucide-react": "^0.563.0",
    "overlayscrollbars": "^2.15.1",
    "overlayscrollbars-react": "^0.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.5.0",
    "react-katex": "^3.1.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^5.0.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^6.0.2",
    "vite": "^7.2.4",
    "vitest": "^4.0.18"
  }
}
