// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
        return request.auth != null;
    }

    function currentUserPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasCurrentUserDoc() {
      return isSignedIn() && exists(currentUserPath());
    }

    function isOnboardingBootstrapUser() {
      return isSignedIn() && !hasCurrentUserDoc();
    }

    function currentUserRole() {
      return hasCurrentUserDoc() ? get(currentUserPath()).data.role : null;
    }

    function currentUserInstitutionId() {
      return hasCurrentUserDoc() ? get(currentUserPath()).data.institutionId : null;
    }

    function isGlobalAdmin() {
      return currentUserRole() == 'admin';
    }

    function isInstitutionAdmin() {
      return currentUserRole() == 'institutionadmin';
    }

    function isTeacherRole() {
      return currentUserRole() == 'teacher';
    }

    function isStudentRole() {
      return currentUserRole() == 'student';
    }

    function hasInstitutionField(data) {
      return data.keys().hasAny(['institutionId']);
    }

    function isOwnerData(data) {
      return data.ownerId == request.auth.uid || data.userId == request.auth.uid;
    }

    function sameInstitution(data) {
      return currentUserInstitutionId() != null && data.institutionId == currentUserInstitutionId();
    }

    function canReadResource(data) {
      return isGlobalAdmin()
        || sameInstitution(data)
        || (!hasInstitutionField(data) && isOwnerData(data));
    }

    function canWriteResource(data) {
      return isGlobalAdmin()
        || sameInstitution(data)
        || (!hasInstitutionField(data) && isOwnerData(data));
    }

    function subjectInstitutionMatches(subjectId) {
      return exists(/databases/$(database)/documents/subjects/$(subjectId))
        && (
          sameInstitution(get(/databases/$(database)/documents/subjects/$(subjectId)).data)
          || (
            !hasInstitutionField(get(/databases/$(database)/documents/subjects/$(subjectId)).data)
            && isOwnerData(get(/databases/$(database)/documents/subjects/$(subjectId)).data)
          )
        );
    }

    function hasSubjectRef(data) {
      return data.keys().hasAny(['subjectId', 'subject_id']);
    }

    function subjectRef(data) {
      return data.keys().hasAny(['subjectId']) ? data.subjectId : data.subject_id;
    }

    function hasTopicRef(data) {
      return data.keys().hasAny(['topicId', 'topic_id']);
    }

    function topicRef(data) {
      return data.keys().hasAny(['topicId']) ? data.topicId : data.topic_id;
    }

    function topicInstitutionMatches(topicId) {
      return exists(/databases/$(database)/documents/topics/$(topicId))
        && (
          sameInstitution(get(/databases/$(database)/documents/topics/$(topicId)).data)
          || (
            !hasInstitutionField(get(/databases/$(database)/documents/topics/$(topicId)).data)
            && (
              (
                hasSubjectRef(get(/databases/$(database)/documents/topics/$(topicId)).data)
                && subjectInstitutionMatches(subjectRef(get(/databases/$(database)/documents/topics/$(topicId)).data))
              )
              || isOwnerData(get(/databases/$(database)/documents/topics/$(topicId)).data)
            )
          )
        );
    }

    function canManageInstitution(institutionId) {
      return isGlobalAdmin()
        || (
          isInstitutionAdmin()
          && currentUserInstitutionId() != null
          && institutionId == currentUserInstitutionId()
        );
    }

    function inviteCodeKeyMatchesInstitution(inviteCodeKey, institutionId) {
      return inviteCodeKey is string
        && institutionId is string
        && institutionId.size() > 0
        && inviteCodeKey.matches('^' + institutionId + '_[A-Za-z0-9]+$');
    }

    function allowsTeacherAutonomousSubjectCreation(institutionId) {
      return institutionId == null
        || !exists(/databases/$(database)/documents/institutions/$(institutionId))
        || !get(/databases/$(database)/documents/institutions/$(institutionId)).data.keys().hasAny(['accessPolicies'])
        || !(get(/databases/$(database)/documents/institutions/$(institutionId)).data.accessPolicies is map)
        || !get(/databases/$(database)/documents/institutions/$(institutionId)).data.accessPolicies.keys().hasAny(['teachers'])
        || !(get(/databases/$(database)/documents/institutions/$(institutionId)).data.accessPolicies.teachers is map)
        || !get(/databases/$(database)/documents/institutions/$(institutionId)).data.accessPolicies.teachers.keys().hasAny(['allowTeacherAutonomousSubjectCreation'])
        || get(/databases/$(database)/documents/institutions/$(institutionId)).data.accessPolicies.teachers.allowTeacherAutonomousSubjectCreation == true;
    }

    function classBelongsToInstitution(classId, institutionId) {
      return classId == null
        || (
          classId is string
          && classId.size() > 0
          && exists(/databases/$(database)/documents/classes/$(classId))
          && get(/databases/$(database)/documents/classes/$(classId)).data.institutionId == institutionId
        );
    }

    function subjectSharedWithUids(data) {
      return data.keys().hasAny(['sharedWithUids']) && data.sharedWithUids is list
        ? data.sharedWithUids
        : [];
    }

    function subjectEnrolledStudentUids(data) {
      return data.keys().hasAny(['enrolledStudentUids']) && data.enrolledStudentUids is list
        ? data.enrolledStudentUids
        : [];
    }

    function canStudentJoinSubjectByInvite() {
      return isStudentRole()
        && sameInstitution(resource.data)
        && request.resource.data.institutionId == resource.data.institutionId
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.course == resource.data.course
        && (!resource.data.keys().hasAny(['status']) || resource.data.status != 'trashed')
        && (!resource.data.keys().hasAny(['inviteCodeEnabled']) || resource.data.inviteCodeEnabled == true)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['sharedWithUids', 'enrolledStudentUids', 'isShared', 'updatedAt'])
        && request.resource.data.isShared == true
        && !(request.auth.uid in subjectSharedWithUids(resource.data))
        && !(request.auth.uid in subjectEnrolledStudentUids(resource.data))
        && request.auth.uid in subjectSharedWithUids(request.resource.data)
        && request.auth.uid in subjectEnrolledStudentUids(request.resource.data)
        && subjectSharedWithUids(request.resource.data).hasAll(subjectSharedWithUids(resource.data))
        && subjectEnrolledStudentUids(request.resource.data).hasAll(subjectEnrolledStudentUids(resource.data))
        && subjectSharedWithUids(request.resource.data).size() == subjectSharedWithUids(resource.data).size() + 1
        && subjectEnrolledStudentUids(request.resource.data).size() == subjectEnrolledStudentUids(resource.data).size() + 1;
    }
    
    function isOwner() {
        return resource.data.ownerId == request.auth.uid || resource.data.userId == request.auth.uid;
    }
    
    function isShared() {
      // verify the field exists and the user's UID is inside it
      return request.auth.uid in resource.data.sharedWithUids;
    }

    function validShortcutCreatePayload() {
      return request.resource.data.keys().hasAll([
        'ownerId',
        'parentId',
        'targetId',
        'targetType',
        'institutionId',
        'createdAt'
      ])
      && (request.resource.data.targetType == 'subject' || request.resource.data.targetType == 'folder');
    }

    function isTargetOwnerForCreate() {
      return (
        request.resource.data.targetType == 'subject'
        && exists(/databases/$(database)/documents/subjects/$(request.resource.data.targetId))
        && (
          get(/databases/$(database)/documents/subjects/$(request.resource.data.targetId)).data.ownerId == request.auth.uid
          || get(/databases/$(database)/documents/subjects/$(request.resource.data.targetId)).data.uid == request.auth.uid
        )
      )
      || (
        request.resource.data.targetType == 'folder'
        && exists(/databases/$(database)/documents/folders/$(request.resource.data.targetId))
        && (
          get(/databases/$(database)/documents/folders/$(request.resource.data.targetId)).data.ownerId == request.auth.uid
          || get(/databases/$(database)/documents/folders/$(request.resource.data.targetId)).data.uid == request.auth.uid
        )
      );
    }

    function targetSharedWithShortcutOwner() {
      return (
        request.resource.data.targetType == 'subject'
        && exists(/databases/$(database)/documents/subjects/$(request.resource.data.targetId))
        && (
          request.resource.data.ownerId in get(/databases/$(database)/documents/subjects/$(request.resource.data.targetId)).data.sharedWithUids
        )
      )
      || (
        request.resource.data.targetType == 'folder'
        && exists(/databases/$(database)/documents/folders/$(request.resource.data.targetId))
        && (
          request.resource.data.ownerId in get(/databases/$(database)/documents/folders/$(request.resource.data.targetId)).data.sharedWithUids
        )
      );
    }

    function canManageFolderById(folderId) {
      return folderId != null
        && exists(/databases/$(database)/documents/folders/$(folderId))
        && (
          isGlobalAdmin()
          || get(/databases/$(database)/documents/folders/$(folderId)).data.ownerId == request.auth.uid
          || get(/databases/$(database)/documents/folders/$(folderId)).data.uid == request.auth.uid
        );
    }

    function subjectReadableByRef(subjectId) {
      return exists(/databases/$(database)/documents/subjects/$(subjectId))
        && (
          canReadResource(get(/databases/$(database)/documents/subjects/$(subjectId)).data)
          || get(/databases/$(database)/documents/subjects/$(subjectId)).data.ownerId == request.auth.uid
          || get(/databases/$(database)/documents/subjects/$(subjectId)).data.uid == request.auth.uid
          || (
            get(/databases/$(database)/documents/subjects/$(subjectId)).data.keys().hasAny(['folderId'])
            && canManageFolderById(get(/databases/$(database)/documents/subjects/$(subjectId)).data.folderId)
          )
          || (
            get(/databases/$(database)/documents/subjects/$(subjectId)).data.keys().hasAny(['sharedWithUids'])
            && request.auth.uid in get(/databases/$(database)/documents/subjects/$(subjectId)).data.sharedWithUids
          )
        );
    }
    
    // Reglas para usuarios
    match /users/{userId} {
      allow read: if isSignedIn();

      // Self bootstrap/create profile
      allow create: if isSignedIn() && request.auth.uid == userId;

      // Update rules:
      // - Global admin: full control
      // - Institution admin: manage users in own institution (never promote to global admin)
      // - Teacher: can only update student recognition fields in same institution
      // - Self: profile updates only, cannot mutate role/institutionId
      allow update: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            isInstitutionAdmin()
            && resource.data.institutionId == currentUserInstitutionId()
            && request.resource.data.institutionId == currentUserInstitutionId()
            && request.resource.data.role != 'admin'
          )
          || (
            isTeacherRole()
            && resource.data.role == 'student'
            && resource.data.institutionId == currentUserInstitutionId()
            && request.resource.data.role == resource.data.role
            && request.resource.data.institutionId == resource.data.institutionId
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['badges', 'badgesByCourse', 'behaviorScore', 'updatedAt'])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['badges'])
              || request.resource.data.badges is list
            )
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['badgesByCourse'])
              || request.resource.data.badgesByCourse is map
            )
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny(['behaviorScore'])
              || request.resource.data.behaviorScore is number
            )
          )
          || (
            request.auth.uid == userId
            && request.resource.data.role == resource.data.role
            && request.resource.data.institutionId == resource.data.institutionId
          )
        );

      // User self-delete or global admin delete
      allow delete: if isSignedIn() && (request.auth.uid == userId || isGlobalAdmin());
    }

    // Reglas principales de Asignaturas
    match /subjects/{subjectId} {
      allow create: if isSignedIn()
        && !isStudentRole()
        && (
          !isTeacherRole()
          || allowsTeacherAutonomousSubjectCreation(request.resource.data.institutionId)
        )
        && (
          isGlobalAdmin()
          || (
            currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
          )
          || request.resource.data.ownerId == request.auth.uid
        )
          && request.resource.data.keys().hasAll(['course'])
        && request.resource.data.course is string
        && request.resource.data.course.size() > 0
          && (
            !request.resource.data.keys().hasAny(['inviteCode'])
            || (
              request.resource.data.inviteCode is string
              && request.resource.data.inviteCode.size() > 0
            )
          )
          && (
            !request.resource.data.keys().hasAny(['enrolledStudentUids'])
            || request.resource.data.enrolledStudentUids is list
          )
        && (
          !request.resource.data.keys().hasAny(['classId'])
          || classBelongsToInstitution(request.resource.data.classId, request.resource.data.institutionId)
        )
        && (
          !request.resource.data.keys().hasAny(['inviteCodeEnabled'])
          || request.resource.data.inviteCodeEnabled is bool
        )
        && (
          !request.resource.data.keys().hasAny(['inviteCodeRotationIntervalHours'])
          || (
            request.resource.data.inviteCodeRotationIntervalHours is number
            && request.resource.data.inviteCodeRotationIntervalHours >= 1
            && request.resource.data.inviteCodeRotationIntervalHours <= 168
          )
        )
        && (
          !request.resource.data.keys().hasAny(['inviteCodeLastRotatedAt'])
          || request.resource.data.inviteCodeLastRotatedAt is timestamp
        );
      allow read: if isSignedIn()
        && (
          canReadResource(resource.data)
          || (
            isOnboardingBootstrapUser()
            && resource.data.keys().hasAny(['isShared'])
            && resource.data.isShared == true
          )
          || resource.data.ownerId == request.auth.uid
          || resource.data.uid == request.auth.uid
          || (
            resource.data.keys().hasAny(['folderId'])
            && canManageFolderById(resource.data.folderId)
          )
          || (resource.data.keys().hasAny(['sharedWithUids']) && request.auth.uid in resource.data.sharedWithUids)
        );
      allow update: if isSignedIn()
        && (
          (
            !isStudentRole()
            && (
              canWriteResource(resource.data)
              || resource.data.ownerId == request.auth.uid
              || resource.data.uid == request.auth.uid
              || (
                resource.data.keys().hasAny(['folderId'])
                && canManageFolderById(resource.data.folderId)
              )
            )
            && (
              !request.writeFields.hasAny(['inviteCode'])
              || (
                request.resource.data.inviteCode is string
                && request.resource.data.inviteCode.size() > 0
              )
            )
            && (
              !request.writeFields.hasAny(['enrolledStudentUids'])
              || request.resource.data.enrolledStudentUids is list
            )
            && (
              !request.writeFields.hasAny(['classId'])
              || classBelongsToInstitution(request.resource.data.classId, request.resource.data.institutionId)
            )
            && (
              !request.writeFields.hasAny(['inviteCodeEnabled'])
              || request.resource.data.inviteCodeEnabled is bool
            )
            && (
              !request.writeFields.hasAny(['inviteCodeRotationIntervalHours'])
              || (
                request.resource.data.inviteCodeRotationIntervalHours is number
                && request.resource.data.inviteCodeRotationIntervalHours >= 1
                && request.resource.data.inviteCodeRotationIntervalHours <= 168
              )
            )
            && (
              !request.writeFields.hasAny(['inviteCodeLastRotatedAt'])
              || request.resource.data.inviteCodeLastRotatedAt is timestamp
            )
          )
          || canStudentJoinSubjectByInvite()
        );
      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.ownerId == request.auth.uid
          || resource.data.uid == request.auth.uid
          || (isInstitutionAdmin() && sameInstitution(resource.data))
        );

      // Reglas para la subcolección "topics"
      match /topics/{topicId} {
        allow read: if isSignedIn()
          && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
        allow write: if isSignedIn()
          && !isStudentRole()
          && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));

        // 1. Pestaña "Generados por IA" (FALTABA ESTO)
        match /resumen/{docId} {
          allow read: if isSignedIn()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
          allow write: if isSignedIn()
            && !isStudentRole()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
        }

        // 2. Pestaña "Mis Archivos" (FALTABA ESTO)
        match /materials/{docId} {
          allow read: if isSignedIn()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
          allow write: if isSignedIn()
            && !isStudentRole()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
        }

        // 3. Tests y Resultados (Ya los tenías)
        match /quizzes/{quizId} {
          allow read: if isSignedIn()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
          allow write: if isSignedIn()
            && !isStudentRole()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
        }
        match /quiz_results/{resultId} {
          allow read: if isSignedIn()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
          allow write: if isSignedIn()
            && !isStudentRole()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
        }
        match /documents/{docId} {
          allow read: if isSignedIn()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
          allow write: if isSignedIn()
            && !isStudentRole()
            && (isGlobalAdmin() || subjectInstitutionMatches(subjectId));
        }
      }
    }

    // Reserva atomica de codigos de invitacion para asignaturas
    match /subjectInviteCodes/{inviteCodeKey} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['inviteCode', 'institutionId', 'subjectId', 'createdBy', 'createdAt'])
        && request.resource.data.inviteCode is string
        && request.resource.data.inviteCode.size() > 0
        && request.resource.data.subjectId is string
        && request.resource.data.subjectId.size() > 0
        && request.resource.data.createdBy == request.auth.uid
        && (
          isGlobalAdmin()
          || (
            currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            && existsAfter(/databases/$(database)/documents/subjects/$(request.resource.data.subjectId))
            && (
              getAfter(/databases/$(database)/documents/subjects/$(request.resource.data.subjectId)).data.ownerId == request.auth.uid
              || (isTeacherRole() && sameInstitution(getAfter(/databases/$(database)/documents/subjects/$(request.resource.data.subjectId)).data))
            )
          )
        );
      allow get: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            currentUserInstitutionId() != null
            && (
              (resource != null
                && resource.data.institutionId == currentUserInstitutionId())
              || (
                resource == null
                && !isStudentRole()
                && inviteCodeKeyMatchesInstitution(inviteCodeKey, currentUserInstitutionId())
              )
            )
          )
        );
      allow list: if false;
      allow update, delete: if false;
    }
    
    // Reglas para Carpetas (Folders)
    match /folders/{folderId} {
      allow create: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            currentUserInstitutionId() != null
            && request.resource.data.keys().hasAny(['institutionId'])
            && request.resource.data.institutionId == currentUserInstitutionId()
          )
        );
      allow read: if isSignedIn()
        && !isStudentRole()
        && (
          canReadResource(resource.data)
          || resource.data.ownerId == request.auth.uid
          || resource.data.uid == request.auth.uid
          || (
            resource.data.keys().hasAny(['parentId'])
            && canManageFolderById(resource.data.parentId)
          )
          || (resource.data.keys().hasAny(['sharedWithUids']) && request.auth.uid in resource.data.sharedWithUids)
        );
      allow update: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            currentUserInstitutionId() != null
            && request.resource.data.keys().hasAny(['institutionId'])
            && request.resource.data.institutionId == currentUserInstitutionId()
            && (
              canWriteResource(resource.data)
              || resource.data.ownerId == request.auth.uid
              || resource.data.uid == request.auth.uid
              || (
                resource.data.keys().hasAny(['parentId'])
                && canManageFolderById(resource.data.parentId)
              )
            )
          )
        );
      allow delete: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || resource.data.ownerId == request.auth.uid
          || resource.data.uid == request.auth.uid
        );
    }

    // Reglas para Temas (Topics) en colección raíz
    match /topics/{topicId} {
      allow create: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            &&
            hasSubjectRef(request.resource.data)
            && subjectInstitutionMatches(subjectRef(request.resource.data))
          )
        );

      allow read: if isSignedIn()
        && (
          canReadResource(resource.data)
          || (
            hasSubjectRef(resource.data)
            && subjectReadableByRef(subjectRef(resource.data))
            && subjectReadableByRef(subjectRef(resource.data))
          )
          || resource.data.ownerId == request.auth.uid
        );

      allow update: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            &&
            hasSubjectRef(resource.data)
            && subjectInstitutionMatches(subjectRef(resource.data))
          )
        );

      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.ownerId == request.auth.uid
          || (
            hasSubjectRef(resource.data)
            && subjectInstitutionMatches(subjectRef(resource.data))
          )
        );
    }

    // Reglas para Documentos (Documents) en colección raíz
    match /documents/{documentId} {
      allow create: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            &&
            hasTopicRef(request.resource.data)
            && topicInstitutionMatches(topicRef(request.resource.data))
          )
        );

      allow read: if isSignedIn()
        && (
          canReadResource(resource.data)
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || (
            hasSubjectRef(resource.data)
            && subjectInstitutionMatches(subjectRef(resource.data))
          )
          || (
            hasSubjectRef(resource.data)
            && subjectInstitutionMatches(subjectRef(resource.data))
          )
          || resource.data.ownerId == request.auth.uid
        );

      allow update: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            &&
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );

      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.ownerId == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );
    }

    // Reglas para Resumen en colección raíz
    match /resumen/{resumenId} {
      allow create: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            hasTopicRef(request.resource.data)
            && topicInstitutionMatches(topicRef(request.resource.data))
            && request.resource.data.institutionId == currentUserInstitutionId()
          )
          || request.resource.data.ownerId == request.auth.uid
        );

      allow read: if isSignedIn()
        && (
          canReadResource(resource.data)
          || (
            hasTopicRef(resource.data)
            && topicReadableByRef(topicRef(resource.data))
          )
          || (
            hasSubjectRef(resource.data)
            && subjectReadableByRef(subjectRef(resource.data))
          )
          || resource.data.ownerId == request.auth.uid
        );

      allow update: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || resource.data.ownerId == request.auth.uid
        );

      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.ownerId == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );
    }

    // Reglas para Quizzes en colección raíz
    match /quizzes/{quizId} {
      allow create: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            &&
            hasTopicRef(request.resource.data)
            && topicInstitutionMatches(topicRef(request.resource.data))
          )
        );

      allow read: if isSignedIn()
        && (
          canReadResource(resource.data)
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || resource.data.ownerId == request.auth.uid
        );

      allow update: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            &&
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );

      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.ownerId == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );
    }

    // Reglas para tareas por tema
    match /topicAssignments/{assignmentId} {
      allow create: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            && hasTopicRef(request.resource.data)
            && topicInstitutionMatches(topicRef(request.resource.data))
          )
          || (
            hasTopicRef(request.resource.data)
            && exists(/databases/$(database)/documents/topics/$(topicRef(request.resource.data)))
            && request.resource.data.createdBy == request.auth.uid
          )
        );

      allow read: if isSignedIn()
        && (
          canReadResource(resource.data)
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || resource.data.createdBy == request.auth.uid
        );

      allow update: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && resource.data.institutionId == currentUserInstitutionId()
            && hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || (
            resource.data.createdBy == request.auth.uid
            && hasTopicRef(resource.data)
            && exists(/databases/$(database)/documents/topics/$(topicRef(resource.data)))
          )
        );

      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.createdBy == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );
    }

    // Entregas de tareas por alumno
    match /topicAssignmentSubmissions/{submissionId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['assignmentId', 'topicId', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && hasTopicRef(request.resource.data)
        && exists(/databases/$(database)/documents/topicAssignments/$(request.resource.data.assignmentId))
        && get(/databases/$(database)/documents/topicAssignments/$(request.resource.data.assignmentId)).data.topicId == request.resource.data.topicId
        && (
          topicInstitutionMatches(topicRef(request.resource.data))
          || (
            get(/databases/$(database)/documents/topicAssignments/$(request.resource.data.assignmentId)).data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && get(/databases/$(database)/documents/topicAssignments/$(request.resource.data.assignmentId)).data.institutionId == currentUserInstitutionId()
          )
        );

      allow read: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.userId == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || (
            resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && resource.data.institutionId == currentUserInstitutionId()
          )
        );

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && hasTopicRef(resource.data)
        && (
          topicInstitutionMatches(topicRef(resource.data))
          || (
            resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && resource.data.institutionId == currentUserInstitutionId()
          )
        );

      allow delete: if false;
    }

    // Reglas para tareas por tema
    match /topicAssignments/{assignmentId} {
      allow create: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && request.resource.data.institutionId == currentUserInstitutionId()
            && hasTopicRef(request.resource.data)
            && topicInstitutionMatches(topicRef(request.resource.data))
          )
          || (
            hasTopicRef(request.resource.data)
            && exists(/databases/$(database)/documents/topics/$(topicRef(request.resource.data)))
            && request.resource.data.createdBy == request.auth.uid
          )
        );

      allow read: if isSignedIn()
        && (
          canReadResource(resource.data)
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || resource.data.createdBy == request.auth.uid
        );

      allow update: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && resource.data.institutionId == currentUserInstitutionId()
            && hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || (
            resource.data.createdBy == request.auth.uid
            && hasTopicRef(resource.data)
            && exists(/databases/$(database)/documents/topics/$(topicRef(resource.data)))
          )
        );

      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.createdBy == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );
    }

    // Entregas de tareas por alumno
    match /topicAssignmentSubmissions/{submissionId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['assignmentId', 'topicId', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && hasTopicRef(request.resource.data)
        && exists(/databases/$(database)/documents/topicAssignments/$(request.resource.data.assignmentId))
        && get(/databases/$(database)/documents/topicAssignments/$(request.resource.data.assignmentId)).data.topicId == request.resource.data.topicId
        && (
          topicInstitutionMatches(topicRef(request.resource.data))
          || (
            get(/databases/$(database)/documents/topicAssignments/$(request.resource.data.assignmentId)).data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && get(/databases/$(database)/documents/topicAssignments/$(request.resource.data.assignmentId)).data.institutionId == currentUserInstitutionId()
          )
        );

      allow read: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.userId == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || (
            resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && resource.data.institutionId == currentUserInstitutionId()
          )
        );

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && hasTopicRef(resource.data)
        && (
          topicInstitutionMatches(topicRef(resource.data))
          || (
            resource.data.keys().hasAny(['institutionId'])
            && currentUserInstitutionId() != null
            && resource.data.institutionId == currentUserInstitutionId()
          )
        );

      allow delete: if false;
    }

    // Historial de intentos por test (inmutable por intento)
    match /quizAttempts/{attemptId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['userId', 'quizId', 'subjectId', 'topicId', 'completedAt'])
        && request.resource.data.userId == request.auth.uid
        && hasTopicRef(request.resource.data)
        && topicInstitutionMatches(topicRef(request.resource.data));

      allow read: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.userId == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );

      allow update, delete: if false;
    }

    // Preguntas dominadas en repaso por alumno y tema
    match /repasoMastered/{repasoId} {
      allow create: if isSignedIn()
        && request.resource.data.keys().hasAll(['userId', 'topicId'])
        && request.resource.data.userId == request.auth.uid
        && hasTopicRef(request.resource.data)
        && topicInstitutionMatches(topicRef(request.resource.data));

      allow read: if isSignedIn()
        && repasoId.matches('^' + request.auth.uid + '__.*$');

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && hasTopicRef(resource.data)
        && topicInstitutionMatches(topicRef(resource.data));

      allow delete: if false;
    }

    // Reglas para items de evaluación extra (grades panel)
    match /subjectEvaluationItems/{itemId} {
      allow read: if isSignedIn()
        && (
          isGlobalAdmin()
          || canReadResource(resource.data)
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
      allow create: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(request.resource.data.subjectId)
          )
        );
      allow update: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
    }

    // Reglas para notas de evaluación extra
    match /subjectEvaluationGrades/{gradeId} {
      allow read: if isSignedIn()
        && (
          isGlobalAdmin()
          || canReadResource(resource.data)
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
      allow create: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(request.resource.data.subjectId)
          )
        );
      allow update: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
    }

    // Reglas para revisiones de tareas entregables
    match /subjectAssignmentGradeReviews/{reviewId} {
      allow read: if isSignedIn()
        && (
          isGlobalAdmin()
          || canReadResource(resource.data)
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
      allow create: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(request.resource.data.subjectId)
          )
        );
      allow update: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
    }

    // Reglas para revisiones de exámenes
    match /subjectExamGradeReviews/{reviewId} {
      allow read: if isSignedIn()
        && (
          isGlobalAdmin()
          || canReadResource(resource.data)
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
      allow create: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            request.resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(request.resource.data.subjectId)
          )
        );
      allow update: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            resource.data.keys().hasAny(['subjectId'])
            && subjectInstitutionMatches(resource.data.subjectId)
          )
        );
    }

    // Reglas para Shortcuts (en la raíz)
    match /shortcuts/{shortcutId} {
      // Owner can create own shortcut OR target owner can create shortcut for a shared recipient (share flow)
      allow create: if isSignedIn()
        && !(isStudentRole() && request.resource.data.targetType == 'folder')
        && request.resource.data.institutionId == currentUserInstitutionId()
        && validShortcutCreatePayload()
        && (
          // Shortcut owner creating their own shortcut (normal case)
          request.resource.data.ownerId == request.auth.uid
          // OR: Folder/subject owner creating shortcut for a recipient (share flow)
          || (
            request.resource.data.ownerId != request.auth.uid
            && isTargetOwnerForCreate()
            // Enforce: recipient must already be shared with target (no || true bypass)
            && targetSharedWithShortcutOwner()
          )
        );
      // Shortcut owner can always read their own shortcut.
      // Target owners can read only within same institution boundary.
      allow read: if isSignedIn() && (
        (
          resource.data.ownerId == request.auth.uid
          && !(isStudentRole() && resource.data.targetType == 'folder')
        )
        || (
          sameInstitution(resource.data)
          && (
            (
              resource.data.targetType == 'subject'
              && exists(/databases/$(database)/documents/subjects/$(resource.data.targetId))
              && (
                get(/databases/$(database)/documents/subjects/$(resource.data.targetId)).data.ownerId == request.auth.uid
                || get(/databases/$(database)/documents/subjects/$(resource.data.targetId)).data.uid == request.auth.uid
              )
            )
            || (
              resource.data.targetType == 'folder'
              && exists(/databases/$(database)/documents/folders/$(resource.data.targetId))
              && (
                get(/databases/$(database)/documents/folders/$(resource.data.targetId)).data.ownerId == request.auth.uid
                || get(/databases/$(database)/documents/folders/$(resource.data.targetId)).data.uid == request.auth.uid
              )
            )
          )
        )
      );
      allow delete, update: if isSignedIn()
        && !(isStudentRole() && resource.data.targetType == 'folder')
        && (
          resource.data.ownerId == request.auth.uid
          // Subject shortcut: subject owner, subject manager, or folder manager
          || (
            resource.data.targetType == 'subject'
            && exists(/databases/$(database)/documents/subjects/$(resource.data.targetId))
            && (
              get(/databases/$(database)/documents/subjects/$(resource.data.targetId)).data.ownerId == request.auth.uid
              || get(/databases/$(database)/documents/subjects/$(resource.data.targetId)).data.uid == request.auth.uid
              || canWriteResource(get(/databases/$(database)/documents/subjects/$(resource.data.targetId)).data)
              || (
                get(/databases/$(database)/documents/subjects/$(resource.data.targetId)).data.keys().hasAny(['folderId'])
                && canManageFolderById(get(/databases/$(database)/documents/subjects/$(resource.data.targetId)).data.folderId)
              )
            )
          )
          // Folder shortcut: folder owner, folder manager, or manager of parent folder (cascade)
          || (
            resource.data.targetType == 'folder'
            && exists(/databases/$(database)/documents/folders/$(resource.data.targetId))
            && (
              get(/databases/$(database)/documents/folders/$(resource.data.targetId)).data.ownerId == request.auth.uid
              || get(/databases/$(database)/documents/folders/$(resource.data.targetId)).data.uid == request.auth.uid
              || canWriteResource(get(/databases/$(database)/documents/folders/$(resource.data.targetId)).data)
              || canManageFolderById(resource.data.targetId)
              || (
                get(/databases/$(database)/documents/folders/$(resource.data.targetId)).data.parentId != null
                && canManageFolderById(get(/databases/$(database)/documents/folders/$(resource.data.targetId)).data.parentId)
              )
            )
          )
        );
    }

    match /classes/{classId} {
      allow create: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            isInstitutionAdmin()
            && request.resource.data.institutionId == currentUserInstitutionId()
          )
        );
      allow read: if isSignedIn() && (
        isGlobalAdmin() || sameInstitution(resource.data)
      );
      allow update, delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            isInstitutionAdmin()
            &&
            sameInstitution(resource.data)
            && request.resource.data.institutionId == resource.data.institutionId
          )
        );
    }

    match /subject_class_requests/{requestId} {
      allow create: if isSignedIn()
        && request.resource.data.institutionId == currentUserInstitutionId()
        && (
          isGlobalAdmin()
          || isInstitutionAdmin()
          || (
            isTeacherRole()
            && request.resource.data.teacherId == request.auth.uid
            && request.resource.data.status == 'pending'
          )
        );

      allow read: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            sameInstitution(resource.data)
            && (
              isInstitutionAdmin()
              || resource.data.teacherId == request.auth.uid
            )
          )
        );

      allow update, delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            isInstitutionAdmin()
            && sameInstitution(resource.data)
            && request.resource.data.institutionId == resource.data.institutionId
          )
        );
    }

    match /courses/{courseId} {
      allow create: if isSignedIn()
        && (
          isGlobalAdmin()
          || request.resource.data.institutionId == currentUserInstitutionId()
        );
      allow read: if isSignedIn() && (
        isGlobalAdmin() || sameInstitution(resource.data)
      );
      allow update, delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || (
            sameInstitution(resource.data)
            && request.resource.data.institutionId == resource.data.institutionId
          )
        );
    }



    // -----------------------------------------
    // INSTITUTIONS
    // -----------------------------------------
    match /institutions/{institutionId} {
      allow get: if true;
      allow read: if isSignedIn();
      allow create, write, update, list: if isGlobalAdmin();
      allow update: if canManageInstitution(institutionId);
      allow delete: if isGlobalAdmin();
    }
    match /institution_invites/{inviteId} {
      // Anyone with the exact code can read it to register
      allow get: if true; 
      
      // LIST: Global Admins can see all. Institution Admins can only see invites for their own school.
      allow list: if isGlobalAdmin() || 
                  (request.auth != null && 
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'institutionadmin' &&
                   get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId == resource.data.institutionId);
      
      // CREATE: Global Admins can create anything. 
      // Institution Admins can only create invites if:
      // 1. They are an institutionadmin
      // 2. The invite is for their own institutionId
      // 3. They are only inviting 'teacher' roles (prevents them from creating other admins)
      allow create: if isGlobalAdmin() || 
                    (request.auth != null && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'institutionadmin' &&
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId == request.resource.data.institutionId &&
                     request.resource.data.role == 'teacher');
                     
      allow update: if isGlobalAdmin();
      
      // DELETE: Global Admins, the user who owns the email, OR the Institution Admin of that school
      allow delete: if isGlobalAdmin() || 
                   (
                     request.auth != null
                     && request.auth.token.keys().hasAny(['email'])
                     && resource.data.keys().hasAny(['email'])
                     && request.auth.token.email == resource.data.email
                   ) ||
                   (request.auth != null && 
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'institutionadmin' &&
                    get(/databases/$(database)/documents/users/$(request.auth.uid)).data.institutionId == resource.data.institutionId);
    }

      // -----------------------------------------
      // SHORTCUT MOVE REQUESTS
      // -----------------------------------------
      match /shortcutMoveRequests/{requestId} {
        allow read: if isSignedIn()
          && (
            isGlobalAdmin()
            || resource.data.requesterUid == request.auth.uid
            || resource.data.targetFolderOwnerUid == request.auth.uid
            || (
              isInstitutionAdmin()
              && resource.data.keys().hasAny(['institutionId'])
              && resource.data.institutionId == currentUserInstitutionId()
            )
          );

        // Writable only from trusted server code via Admin SDK.
        allow create, update, delete: if false;
      }

      // -----------------------------------------
      // DIRECT MESSAGES
      // -----------------------------------------
      match /directMessages/{messageId} {
        allow read: if isSignedIn()
          && (
            isGlobalAdmin()
            || (
              resource.data.keys().hasAll(['institutionId', 'senderUid', 'recipientUid'])
              && resource.data.institutionId == currentUserInstitutionId()
              && (
                resource.data.senderUid == request.auth.uid
                || resource.data.recipientUid == request.auth.uid
              )
            )
            || (
              isInstitutionAdmin()
              && resource.data.keys().hasAny(['institutionId'])
              && resource.data.institutionId == currentUserInstitutionId()
            )
          );

        allow create: if isSignedIn()
          && request.resource.data.keys().hasAll(['institutionId', 'senderUid', 'recipientUid', 'content'])
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.recipientUid is string
          && request.resource.data.recipientUid != request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 700
          && request.resource.data.institutionId == currentUserInstitutionId()
          && exists(/databases/$(database)/documents/users/$(request.resource.data.recipientUid))
          && get(/databases/$(database)/documents/users/$(request.resource.data.recipientUid)).data.institutionId == currentUserInstitutionId();

        allow update: if isSignedIn()
          && resource.data.keys().hasAny(['institutionId'])
          && resource.data.institutionId == currentUserInstitutionId()
          && resource.data.recipientUid == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readByRecipient', 'readAt', 'updatedAt'])
          && request.resource.data.readByRecipient == true;

        allow delete: if isSignedIn() && isGlobalAdmin();
      }

      // -----------------------------------------
      // NOTIFICATIONS
      // -----------------------------------------
      match /notifications/{notificationId} {
        allow read: if isSignedIn()
          && (
            isGlobalAdmin()
            || resource.data.userId == request.auth.uid
            || (
              isInstitutionAdmin()
              && resource.data.keys().hasAny(['institutionId'])
              && resource.data.institutionId == currentUserInstitutionId()
            )
          );

        allow create: if isSignedIn()
          && (
            isGlobalAdmin()
            || request.resource.data.userId == request.auth.uid
            || (
              isInstitutionAdmin()
              && request.resource.data.keys().hasAny(['institutionId'])
              && request.resource.data.institutionId == currentUserInstitutionId()
            )
            || (
              request.resource.data.keys().hasAll(['institutionId', 'userId', 'type'])
              && request.resource.data.institutionId == currentUserInstitutionId()
              && (request.resource.data.type == 'subject_shared' || request.resource.data.type == 'direct_message')
              && request.resource.data.userId is string
              && exists(/databases/$(database)/documents/users/$(request.resource.data.userId))
              && get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data.institutionId == currentUserInstitutionId()
            )
          );

        allow update: if isSignedIn()
          && (
            isGlobalAdmin()
            || resource.data.userId == request.auth.uid
            || (
              isInstitutionAdmin()
              && resource.data.keys().hasAny(['institutionId'])
              && resource.data.institutionId == currentUserInstitutionId()
            )
          );

        allow delete: if isSignedIn()
          && (
            isGlobalAdmin()
            || resource.data.userId == request.auth.uid
            || (
              isInstitutionAdmin()
              && resource.data.keys().hasAny(['institutionId'])
              && resource.data.institutionId == currentUserInstitutionId()
            )
          );
      }


    // -----------------------------------------
    // NUEVAS REGLAS PARA EXÁMENES (EXAMS)
    // -----------------------------------------
    match /exams/{examId} {
      allow create: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            hasTopicRef(request.resource.data)
            && topicInstitutionMatches(topicRef(request.resource.data))
            && request.resource.data.institutionId == currentUserInstitutionId()
          )
          || request.resource.data.ownerId == request.auth.uid
        );

      allow read: if isSignedIn()
        && (
          canReadResource(resource.data)
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || resource.data.ownerId == request.auth.uid
        );

      allow update: if isSignedIn()
        && !isStudentRole()
        && (
          isGlobalAdmin()
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
          || resource.data.ownerId == request.auth.uid
        );

      allow delete: if isSignedIn()
        && (
          isGlobalAdmin()
          || resource.data.ownerId == request.auth.uid
          || (
            hasTopicRef(resource.data)
            && topicInstitutionMatches(topicRef(resource.data))
          )
        );
    }
  }
}
